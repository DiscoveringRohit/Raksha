<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="24dp"
        android:paddingBottom="32dp">

        <!-- ══════════════════════════════════════════ -->
        <!--  HEADER                                    -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🛡️"
                android:textSize="48sp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RAKSHA"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:letterSpacing="0.15" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Voice-Triggered Emergency System"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <!-- Thin accent line under header -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:background="@color/primary"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!--  STATUS CARD                               -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_card"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginBottom="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="PROTECTION STATUS"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchService"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:theme="@style/Theme.SafetyApp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⬤  Shield Inactive"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp" />

            <!-- Live Heard Text Panel (hidden by default) -->
            <LinearLayout
                android:id="@+id/tvLastHeard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_heard_panel"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="10dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎙"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvHeardText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Waiting for speech…"
                    android:textSize="13sp"
                    android:textColor="#AAB4FF"
                    android:fontFamily="monospace"
                    android:maxLines="2"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!--  BIG SOS BUTTON (centred circle)           -->
        <!-- ══════════════════════════════════════════ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:gravity="center"
            android:layout_marginBottom="26dp">

            <!-- Outer pulse ring -->
            <View
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:background="@drawable/bg_sos_ring"
                android:layout_centerInParent="true" />

            <!-- Middle ring -->
            <View
                android:layout_width="176dp"
                android:layout_height="176dp"
                android:background="@drawable/bg_sos_ring"
                android:layout_centerInParent="true" />

            <!-- The actual SOS button -->
            <Button
                android:id="@+id/btnSOS"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@drawable/bg_sos_circle"
                android:text="SOS"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_centerInParent="true"
                android:elevation="8dp"
                android:stateListAnimator="@null" />
        </RelativeLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hold to send emergency alert to all contacts"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:layout_marginBottom="28dp" />

        <!-- ══════════════════════════════════════════ -->
        <!--  TRIGGER WORD CARD                         -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎤"
                    android:textSize="20sp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Voice Trigger Word"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="e.g. Help, Bachao, Save me"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#22FFFFFF"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="14dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Trigger word or phrase"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/card_border"
                app:hintTextColor="@color/text_secondary"
                android:layout_marginBottom="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTriggerWord"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text"
                    android:textColor="@color/text_primary"
                    android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveTrigger"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="💾  Save Trigger Word"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                app:strokeWidth="0dp" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!--  EMERGENCY CONTACTS CARD                   -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞"
                    android:textSize="20sp"
                    android:layout_marginEnd="10dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency Contacts"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Will receive SOS with your location"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1px"
                android:background="#22FFFFFF"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="14dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Contact name"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/card_border"
                app:hintTextColor="@color/text_secondary"
                android:layout_marginBottom="10dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContactName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Phone number (e.g. +91XXXXXXXXXX)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/card_border"
                app:hintTextColor="@color/text_secondary"
                android:layout_marginBottom="14dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etContactPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddContact"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="＋  Add Contact"
                android:textColor="@color/white"
                android:textSize="14sp"
                app:backgroundTint="@color/green_dark"
                app:cornerRadius="12dp"
                android:layout_marginBottom="14dp" />

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvNoContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No contacts added yet"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:gravity="center"
                android:padding="12dp"
                android:visibility="visible" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>

        <!-- ══════════════════════════════════════════ -->
        <!--  HOW IT WORKS CARD                         -->
        <!-- ══════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_glass_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ℹ️  How it works"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary_light"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="① Add emergency contacts\n② Set a trigger word\n③ Enable voice monitoring\n④ Say the trigger word → GPS location + 10s recording sent automatically"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:lineSpacingMultiplier="1.6" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
